function fib(n(int)) start
    a(int);
    b(int);
    c(int);
    i(int);

    if (n == 1) start
        return 0;
    end

    if (n == 2) start
        return 1;
    end

    a = 0;
    b = 1;
    i = 3;

    while (i <= n) start
        c = a + b;
        a = b;
        b = c;
        i = i + 1;
    end

    return b;
end

main start
    result(int);
    result = fib(10);
    print(result);
end